# ============================================
# VerbumDigital Web Radio — Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# Server
PORT=8081

# Database (auto-created by docker compose)
DB_HOST=localhost
DB_PORT=3306
DB_USER=st1stream
DB_PASSWORD=changeme
DB_NAME=st1

# JWT Authentication
JWT_SECRET=change_this_to_a_random_secret_at_least_32_chars
JWT_EXPIRATION_HOURS=720

# Icecast streaming server (managed by Svilen)
ICECAST_BASE_URL=http://vdserv.com:8000

# ST1 Device Authentication
DEVICE_API_KEY=change_this_to_a_random_key_for_st1_devices

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@verbumdigital.com